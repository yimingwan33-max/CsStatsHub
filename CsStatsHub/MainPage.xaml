<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CsStatsHub.MainPage"
             Title="登录 - CS Stats Hub">

    <Grid>
        <ScrollView x:Name="LoginUI">
            <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

                <Label Text="CS Stats Hub" FontSize="32" HorizontalOptions="Center" FontAttributes="Bold" />

                <Label Text="Username:" FontSize="18" />
                <Entry x:Name="UsernameEntry" Placeholder="Enter username" />

                <Label Text="Password:" FontSize="18" />
                <Entry x:Name="PasswordEntry" Placeholder="Enter password" IsPassword="True" />

                <Button Text="Login" BackgroundColor="#0078D4" TextColor="White" />

                <Label Text="- OR -" HorizontalOptions="Center" TextColor="Gray" Margin="0, 10"/>

                <Button Text="use Steam login"
                        Clicked="OnSteamLoginClicked"
                        BackgroundColor="#171a21"
                        TextColor="White"
                        HorizontalOptions="Center"
                        WidthRequest="250"/>
            </VerticalStackLayout>
        </ScrollView>

        <WebView x:Name="SteamWebView" 
                 IsVisible="False" 
                 Navigating="OnWebViewNavigating" />
    </Grid>

</ContentPage>