<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CsStatsHub.MainPage"
             Title="Sign In - CS Stats Hub"
             BackgroundColor="{StaticResource DarkBackground}">

    <Grid>
        <ScrollView x:Name="LoginUI">
            <VerticalStackLayout Padding="32" Spacing="24" VerticalOptions="Center">

                <Label Text="CS Stats Hub"
                       FontSize="34"
                       HorizontalOptions="Center"
                       FontAttributes="Bold"
                       TextColor="{StaticResource LightOnDarkBackground}" />

                <Label Text="Sign in with Steam OpenID to sync your Counter-Strike stats."
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource Gray400}"
                       LineBreakMode="WordWrap" />

                <Button Text="Sign in with Steam"
                        Clicked="OnSteamLoginClicked"
                        BackgroundColor="#1b2838"
                        BorderColor="#66c0f4"
                        BorderWidth="1"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="52"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </ScrollView>

        <WebView x:Name="SteamWebView"
                 IsVisible="False"
                 Navigating="OnWebViewNavigating" />
    </Grid>

</ContentPage>
