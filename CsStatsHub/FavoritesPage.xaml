<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CsStatsHub.FavoritesPage"
             Title="Favorites">

    <CollectionView x:Name="FavoritesCollection" Margin="20">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame BorderColor="Gray" Margin="0,0,0,15" Padding="0">
                    <VerticalStackLayout>
                        <Label Text="{Binding PlayerInfo}" FontAttributes="Bold" Padding="10,10,10,5" />
                        <BoxView HeightRequest="1" Color="Gray" />
                        <Label Text="{Binding RankInfo}" Padding="10,5,10,10" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>