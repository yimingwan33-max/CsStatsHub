<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CsStatsHub.ProfilePage"
             Title="Profile">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
            <BoxView Color="DarkSlateGray" WidthRequest="80" HeightRequest="80" CornerRadius="40" Grid.Column="0"/>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout>
                    <Label Text="Play name: " FontAttributes="Bold"/>
                    <Label x:Name="NameLabel" />
                </HorizontalStackLayout>
                <HorizontalStackLayout>
                    <Label Text="Rank: " FontAttributes="Bold"/>
                    <Label x:Name="RankLabel" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <ProgressBar x:Name="RankProgressBar" ProgressColor="LightBlue" Margin="0,10" />

        <Frame BorderColor="LightGray" Padding="10">
            <VerticalStackLayout Spacing="5">
                <Label Text="Headshot rate :" />
                <Label x:Name="KDLabel" />
                <HorizontalStackLayout>
                    <Label Text="Matches Played:" />
                    <Label x:Name="MatchesLabel" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <Button Text="view match history" Clicked="OnViewMatchHistoryClicked" BackgroundColor="LightBlue" TextColor="Black" Margin="0,20,0,0"/>
        <Button Text="Show favorites" Clicked="OnShowFavoritesClicked" BackgroundColor="LightBlue" TextColor="Black" />

    </VerticalStackLayout>
</ContentPage>